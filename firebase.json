{
  "hosting": {
    "public": ".",
    "redirects": [
      { "source": "/paginas/funcionario.html", "destination": "/paginas/dashboard-comercial.html", "type": 301 },
      { "source": "/paginas/novo-orcamento.html", "destination": "/paginas/orcamento-inteligente.html", "type": 301 },
      { "source": "/paginas/valores.html", "destination": "/paginas/produtos.html", "type": 301 }
    ],
    "predeploy": [
      "npm run prepare:deploy",
      "npm run refresh:cache",
      "npm run check"
    ],
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "package.json",
      "package-lock.json",
      "README.md",
      "CHANGELOG.md",
      "LIMPEZA_REALIZADA.txt",
      "PUBLICAR.md",
      "**/.*",
      "**/node_modules/**",
      "docs/**",
      "assets/pwa/launch-background.png",
      "patchs/**",
      "scripts/**",
      "tests/**",
      "tmp/**"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": false
    },
    "singleProjectMode": true
  }
}
