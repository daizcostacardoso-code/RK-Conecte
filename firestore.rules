rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function autorizado() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios_autorizados/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios_autorizados/$(request.auth.uid)).data.ativo == true
        && get(/databases/$(database)/documents/usuarios_autorizados/$(request.auth.uid)).data.perfil in ['admin', 'funcionario'];
    }

    function administrador() {
      return autorizado()
        && get(/databases/$(database)/documents/usuarios_autorizados/$(request.auth.uid)).data.perfil == 'admin';
    }

    function perfilValido(uid) {
      let perfil = request.resource.data;
      return perfil.keys().hasAll(['ativo', 'perfil', 'email', 'nome'])
        && perfil.keys().hasOnly(['ativo', 'perfil', 'email', 'nome'])
        && perfil.ativo is bool
        && perfil.perfil in ['admin', 'funcionario']
        && textoEntre(perfil.email, 3, 254)
        && textoEntre(perfil.nome, 2, 120)
        && uid.size() >= 1;
    }

    function textoEntre(valor, minimo, maximo) {
      return valor is string
        && valor.size() >= minimo
        && valor.size() <= maximo;
    }

    function clientePublicoValido(cliente) {
      return cliente is map
        && cliente.keys().hasAll(['nome', 'telefone', 'email', 'endereco'])
        && cliente.keys().hasOnly(['nome', 'telefone', 'email', 'endereco'])
        && textoEntre(cliente.nome, 2, 120)
        && textoEntre(cliente.telefone, 8, 30)
        && textoEntre(cliente.email, 0, 254)
        && textoEntre(cliente.endereco, 0, 300);
    }

    function solicitacaoPublicaValida() {
      let dados = request.resource.data;
      return dados.keys().hasAll([
          'origem', 'cliente', 'nome', 'telefone', 'email', 'endereco',
          'itens', 'servico', 'quantidadeItens', 'subtotal', 'desconto',
          'observacoes', 'descricao', 'mensagem', 'data', 'criadoEmISO', 'status'
        ])
        && dados.keys().hasOnly([
          'origem', 'cliente', 'nome', 'telefone', 'email', 'endereco',
          'itens', 'servico', 'quantidadeItens', 'subtotal', 'desconto',
          'observacoes', 'descricao', 'mensagem', 'data', 'criadoEmISO', 'status'
        ])
        && dados.origem == 'orcamento_cliente'
        && dados.status == 'Solicitado'
        && clientePublicoValido(dados.cliente)
        && dados.nome == dados.cliente.nome
        && dados.telefone == dados.cliente.telefone
        && dados.email == dados.cliente.email
        && dados.endereco == dados.cliente.endereco
        && dados.itens is list
        && dados.itens.size() > 0
        && dados.itens.size() <= 30
        && dados.quantidadeItens is int
        && dados.quantidadeItens == dados.itens.size()
        && dados.subtotal is number
        && dados.subtotal >= 0
        && dados.subtotal <= 100000000
        && dados.desconto is map
        && dados.desconto.keys().hasAll(['tipo', 'valor'])
        && dados.desconto.keys().hasOnly(['tipo', 'valor'])
        && dados.desconto.tipo == 'valor'
        && dados.desconto.valor == 0
        && textoEntre(dados.servico, 1, 2000)
        && textoEntre(dados.observacoes, 0, 2000)
        && textoEntre(dados.descricao, 0, 2000)
        && textoEntre(dados.mensagem, 1, 12000)
        && textoEntre(dados.data, 1, 40)
        && textoEntre(dados.criadoEmISO, 20, 40);
    }

    function projetoOperacionalValido() {
      let projeto = request.resource.data;
      return !projeto.keys().hasAny(['origem'])
        || projeto.origem != 'orcamento_aprovado'
        || (
          projeto.keys().hasAll(['orcamento'])
          && projeto.orcamento is map
          && projeto.orcamento.keys().hasAll(['id'])
          && textoEntre(projeto.orcamento.id, 1, 120)
          && exists(/databases/$(database)/documents/orcamentos_emitidos/$(projeto.orcamento.id))
          && get(/databases/$(database)/documents/orcamentos_emitidos/$(projeto.orcamento.id)).data.status == 'aprovado'
        );
    }

    function vinculoOperacionalExistentePreservado() {
      let anterior = resource.data;
      let projeto = request.resource.data;
      return anterior.keys().hasAll(['origem', 'orcamento'])
        && projeto.keys().hasAll(['origem', 'orcamento'])
        && anterior.origem == 'orcamento_aprovado'
        && projeto.origem == anterior.origem
        && anterior.orcamento is map
        && projeto.orcamento is map
        && anterior.orcamento.id == projeto.orcamento.id;
    }

    function medicaoOperacionalValida() {
      let medicao = request.resource.data;
      return medicao.keys().hasAll(['projetoId', 'status', 'medidas'])
        && textoEntre(medicao.projetoId, 1, 120)
        && medicao.status in ['rascunho', 'concluida']
        && medicao.medidas is list
        && medicao.medidas.size() > 0
        && medicao.medidas.size() <= 200
        && exists(/databases/$(database)/documents/projetos/$(medicao.projetoId))
        && get(/databases/$(database)/documents/projetos/$(medicao.projetoId)).data.status != 'cancelado';
    }

    function vinculoMedicaoPreservado() {
      return resource.data.keys().hasAll(['projetoId'])
        && request.resource.data.keys().hasAll(['projetoId'])
        && resource.data.projetoId == request.resource.data.projetoId;
    }

    function ordemServicoOperacionalValida() {
      let ordem = request.resource.data;
      return !ordem.keys().hasAny(['origem'])
        || ordem.origem != 'projeto_operacional'
        || (
          ordem.keys().hasAll(['projetoId', 'medicaoId', 'status'])
          && textoEntre(ordem.projetoId, 1, 120)
          && textoEntre(ordem.medicaoId, 1, 120)
          && ordem.status in ['rascunho', 'em_producao', 'em_instalacao', 'concluido', 'cancelado']
          && exists(/databases/$(database)/documents/projetos/$(ordem.projetoId))
          && exists(/databases/$(database)/documents/medicoes/$(ordem.medicaoId))
          && get(/databases/$(database)/documents/medicoes/$(ordem.medicaoId)).data.projetoId == ordem.projetoId
          && get(/databases/$(database)/documents/medicoes/$(ordem.medicaoId)).data.status == 'concluida'
        );
    }

    function vinculoOrdemServicoPreservado() {
      return resource.data.keys().hasAll(['projetoId', 'medicaoId'])
        && request.resource.data.keys().hasAll(['projetoId', 'medicaoId'])
        && resource.data.projetoId == request.resource.data.projetoId
        && resource.data.medicaoId == request.resource.data.medicaoId;
    }

    function transicaoOrdemServicoValida() {
      let anterior = resource.data.status;
      let destino = request.resource.data.status;
      return anterior == destino
        || (anterior == 'rascunho' && destino in ['em_producao', 'cancelado'])
        || (anterior == 'em_producao' && destino in ['em_instalacao', 'cancelado'])
        || (anterior == 'em_instalacao' && destino in ['concluido', 'cancelado']);
    }

    // O formulário público usa apenas os valores de cálculo publicados.
    match /configuracoes/valores {
      allow read: if true;
      allow write: if autorizado();
    }

    match /configuracoes/{documento} {
      allow read, write: if autorizado();
    }

    // A autenticação prova a identidade; este cadastro concede autorização.
    // O primeiro administrador deve ser criado pelo Console antes do deploy.
    match /usuarios_autorizados/{uid} {
      allow get: if autorizado() && (request.auth.uid == uid || administrador());
      allow list: if administrador();
      allow create, update: if administrador() && perfilValido(uid);
      allow delete: if administrador() && request.auth.uid != uid;
    }

    // Visitantes podem criar uma solicitação validada, mas nunca consultar,
    // alterar ou excluir solicitações. A equipe autenticada mantém o CRUD.
    match /solicitacoes_site/{documento} {
      allow create: if autorizado() || solicitacaoPublicaValida();
      allow read, update, delete: if autorizado();
    }

    // Coleção legada mantida apenas para consulta durante a compatibilização.
    // Novos orçamentos e alterações usam exclusivamente orcamentos_emitidos.
    match /orcamentos/{documento} {
      allow read: if autorizado();
      allow write: if false;
    }

    match /orcamentos_emitidos/{documento} {
      allow read, create, update: if autorizado();
      allow delete: if false;
    }

    match /projetos/{documento} {
      allow read: if autorizado();
      allow create: if autorizado() && projetoOperacionalValido();
      allow update: if autorizado() && (projetoOperacionalValido() || vinculoOperacionalExistentePreservado());
      allow delete: if false;
    }

    match /medicoes/{documento} {
      allow read: if autorizado();
      allow create: if autorizado() && medicaoOperacionalValida();
      allow update: if autorizado() && medicaoOperacionalValida() && vinculoMedicaoPreservado();
      allow delete: if false;
    }

    match /servicos/{documento} {
      allow read, write: if autorizado();
    }

    match /caixa_empresa/{documento} {
      allow read, write: if autorizado();
    }

    match /clientes/{documento} {
      allow read, write: if autorizado();
    }

    match /produtos/{documento} {
      allow read, write: if autorizado();
    }

    match /itens/{documento} {
      allow read, write: if autorizado();
    }

    match /item_dependencias/{documento} {
      allow read, write: if autorizado();
    }

    match /tamanhos_padrao/{documento} {
      allow read, write: if autorizado();
    }

    match /unidades_medida/{documento} {
      allow read, write: if autorizado();
    }

    match /categorias_produto/{documento} {
      allow read, write: if autorizado();
    }

    match /categorias_item/{documento} {
      allow read, write: if autorizado();
    }

    match /notas_servico/{documento} {
      allow read: if autorizado();
      allow create: if autorizado() && ordemServicoOperacionalValida();
      allow update: if autorizado() && ordemServicoOperacionalValida()
        && (!resource.data.keys().hasAny(['origem'])
          || resource.data.origem != 'projeto_operacional'
          || (vinculoOrdemServicoPreservado() && transicaoOrdemServicoValida()));
      allow delete: if false;
    }

    // Coleções novas ou caminhos não mapeados começam bloqueados.
    match /{documento=**} {
      allow read, write: if false;
    }
  }
}
